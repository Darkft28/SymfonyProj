{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="form-wrapper">
    <h2 class="form-title">Connexion</h2>

    {% if error %}
        <p class="flash-message flash-message--error">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </p>
    {% endif %}

    <form method="post">
        <div>
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="{{ last_username }}" required autofocus autocomplete="email">
        </div>

        <div>
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" required autocomplete="current-password">
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit">Se connecter</button>
    </form>

    <a href="{{ path('app_register') }}" class="form-link">Pas encore de compte ? S'inscrire</a>
</div>
{% endblock %}
