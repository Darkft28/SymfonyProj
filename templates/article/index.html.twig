{% extends 'base.html.twig' %}

{% block title %}Gestion des articles{% endblock %}

{% block body %}
<div class="admin-wrapper">

    <div class="admin-header">
        <h1 class="admin-header__title">Gestion des articles</h1>
        <a href="{{ path('article_new') }}" class="btn btn--primary">+ Nouvel article</a>
    </div>

    {% if articles is empty %}
        <div class="blog-empty">
            <span class="blog-empty__icon" aria-hidden="true">✦</span>
            <p class="blog-empty__text">Aucun article.</p>
        </div>
    {% else %}
        <div class="admin-table-scroll">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Auteur</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for article in articles %}
                        <tr>
                            <td>{{ article.title }}</td>
                            <td>{{ article.author.firstName }} {{ article.author.lastName }}</td>
                            <td>{{ article.status == 'published' ? 'Publié' : 'Brouillon' }}</td>
                            <td>{{ article.publishedAt|date('d/m/Y') }}</td>
                            <td class="admin-table__actions">
                                <a href="{{ path('blog_show', {id: article.id}) }}" class="btn btn--secondary">Voir</a>
                                <a href="{{ path('article_edit', {id: article.id}) }}" class="btn btn--primary">Modifier</a>
                                <form method="post" action="{{ path('article_delete', {id: article.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet article ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                                    <button type="submit" class="btn btn--danger">Supprimer</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

</div>
{% endblock %}
