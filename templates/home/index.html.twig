{% extends 'base.html.twig' %}

{% block title %}Bienvenue — Blog{% endblock %}

{% block body %}

    <section class="hero" aria-label="Introduction">
        <div class="hero__inner">
            <h1 class="hero__title">Écrire, partager,<br>transmettre.</h1>
            <p class="hero__subtitle">
                Un espace de réflexion et de publication. Des articles soignés,
                rédigés avec soin, sur des sujets qui méritent qu'on s'y attarde.
            </p>
            <a href="{{ path('blog_index') }}" class="hero__cta">Lire le blog</a>
        </div>
    </section>

    <section class="home-section" aria-label="Derniers articles">
        <h2 class="home-section__title">Derniers articles</h2>

        {% if articles is empty %}
            <div class="blog-empty">
                <span class="blog-empty__icon" aria-hidden="true">✦</span>
                <p class="blog-empty__text">Aucun article publié pour le moment.</p>
            </div>
        {% else %}
            <ul class="article-list" role="list">
                {% for article in articles %}
                    <li>
                        <article class="article-card">
                            <h2 class="article-card__title">{{ article.title }}</h2>
                            <p class="article-card__meta">
                                <span class="article-card__author">{{ article.author.firstName }} {{ article.author.lastName }}</span>
                                <time class="article-card__date" datetime="{{ article.publishedAt|date('Y-m-d') }}">
                                    {{ article.publishedAt|date('d/m/Y') }}
                                </time>
                                {% if article.category %}
                                    <span class="article-card__category">{{ article.category.name }}</span>
                                {% endif %}
                            </p>
                            <p class="article-card__excerpt">{{ article.content|slice(0, 250) }}…</p>
                            <a href="{{ path('blog_show', {id: article.id}) }}" class="article-card__read">Lire l'article →</a>
                        </article>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

{% endblock %}
